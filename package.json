{
  "name": "pdf-translate-reader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "node server/index.mjs",
    "build": "tsc --noEmit && vite build",
    "deploy:linux:nginx": "bash scripts/deploy-linux-nginx.sh",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.49.8",
    "dotenv": "16.4.7",
    "idb": "8.0.0",
    "lucide-react": "0.468.0",
    "pdfjs-dist": "4.8.69",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "typescript": "5.7.2",
    "vite": "5.4.21"
  }
}
